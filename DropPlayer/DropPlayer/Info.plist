<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Background audio playback -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>

    <!-- Dropbox OAuth redirect URL scheme: db-<YOUR_APP_KEY> -->
    <!-- Replace YOUR_APP_KEY with the key from https://www.dropbox.com/developers/apps -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>db-j94hl849cn6qdou</string>
            </array>
            <key>CFBundleURLName</key>
            <string>com.dropplayer.app</string>
        </dict>
    </array>

    <!-- Allow Dropbox app queries -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>dbapi-8-emm</string>
        <string>dbapi-2</string>
    </array>
</dict>
</plist>
